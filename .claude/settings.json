{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 5,
            "statusMessage": "Loading dev docs context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-strategy-edit.sh",
            "timeout": 5,
            "statusMessage": "Checking strategy changes..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prompt-context.sh",
            "timeout": 5,
            "statusMessage": "Loading active task context..."
          }
        ]
      }
    ]
  }
}
